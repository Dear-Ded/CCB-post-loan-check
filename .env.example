# Optional runtime overrides.
# Leave blank when running inside Codex bundled runtime.
POST_LOAN_NODE_EXE=
POST_LOAN_PYTHON_EXE=
POST_LOAN_NODE_MODULES=
POST_LOAN_CHROME_EXE=

# Optional output folder. Default: %USERPROFILE%\Documents\CCB贷前贷后查询\outputs
POST_LOAN_OUTPUT_ROOT=

# Challenge handling.
# Normal public/authorized/internal sources default to auto and low-risk OCR is enabled.
# Set 0 to disable low-risk OCR.
POST_LOAN_ENABLE_LOW_RISK_OCR=1

# Optional policy and consent files.
POST_LOAN_CHALLENGE_POLICY=
POST_LOAN_RISK_CONSENT_FILE=

# Non-interactive high-risk auto acknowledgement for managed enterprise deployments.
# Prefer scripts/confirm_challenge_risk.ps1 -Accept for desktop use.
POST_LOAN_HIGH_RISK_AUTO_ACK=0

# Enterprise private deployment profile.
# After global risk confirmation, this profile defaults all source classes to auto,
# while still allowing each source to be turned down to assisted or blocked.
POST_LOAN_DEPLOYMENT_PROFILE=
