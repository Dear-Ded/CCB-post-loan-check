    },
    {
      "id": "custom_im_bot_template",
      "name": "即时通讯公共服务 Provider 模板（默认关闭）",
      "type": "im-bot",
      "category": "external-provider",
      "dataCategory": "user-configured-public-service",
      "delivery": "instant-messaging-bot",
      "enabled": false,
      "defaultEnabled": false,
      "admissionClass": "user-configured-provider",
      "publicAccess": false,
      "requiresCredential": false,
      "requiresOperatorReview": true,
      "riskNotice": "即时通讯 Bot 服务质量、来源、条款和数据边界差异很大。框架提供插槽和审计字段，但不把不透明 Bot 作为默认自动数据源。",
      "auth": {
        "type": "none"
      },
      "tags": ["template", "im-bot", "default-off", "operator-review"]
    },
    {
      "id": "custom_public_api_template",
      "name": "自定义公开 API 模板",
      "type": "http-api",
      "enabled": false,
      "defaultEnabled": false,
      "admissionClass": "custom",
      "publicAccess": true,
      "requiresCredential": false,
      "endpoint": "https://example.com/search",
      "queryParam": "q",
      "auth": {
        "type": "none"
      },
      "resultMapping": {
        "recordsPath": "items",
        "titlePath": "title",
        "summaryPath": "summary",
        "urlPath": "url",
        "publishedAtPath": "publishedAt",
        "relatedSubjectsPath": "relatedSubjects"
      },
      "tags": ["template", "public-api"]
    },
    {
      "id": "custom_credentialed_api_template",
      "name": "自定义授权 API 模板（默认关闭）",
      "type": "http-api",
      "enabled": false,
      "defaultEnabled": false,
      "admissionClass": "credentialed-user-configured",
      "publicAccess": false,
      "requiresCredential": true,
      "endpoint": "https://example.com/authorized-search",
      "queryParam": "q",
      "auth": {
        "type": "bearer",
        "env": "POST_LOAN_EXAMPLE_BEARER_TOKEN"
      },
      "resultMapping": {
        "recordsPath": "items",
        "titlePath": "title",
        "summaryPath": "summary",
        "urlPath": "url",
        "publishedAtPath": "publishedAt",
        "relatedSubjectsPath": "relatedSubjects"
      },
      "riskNotice": "需要部署者确认授权、账号条款、数据使用边界后再开启。",
      "tags": ["template", "credentialed", "default-off"]
    }
