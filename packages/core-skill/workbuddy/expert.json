{
  "id": "ccb-post-loan",
  "displayName": "CCB贷前贷后查询",
  "description": "输入企业名称后，执行贷前贷后外部门户查询，校验真实截图证据并生成 Word 报告。",
  "audience": "nonTechnical",
  "platforms": {
    "desktop": {
      "os": "Windows",
      "entrypoint": "workbuddy/run_workbuddy.ps1",
      "commandTemplate": ".\\workbuddy\\run_workbuddy.ps1 -CompanyName \"{companyName}\" {orgCodeArg} {personArgs} -Mode \"{mode}\" {healthArg} -Json"
    }
  },
  "inputs": [
    { "name": "companyName", "label": "企业名称", "type": "text", "required": true },
    {
      "name": "orgCode",
      "label": "统一社会信用代码",
      "type": "text",
      "required": false,
      "help": "不填写时系统会尽力公开查询；查不到或不确定时会写入证据缺口。"
    },
    {
      "name": "mode",
      "label": "查询模式",
      "type": "select",
      "default": "enhanced",
      "options": [
        { "value": "standard", "label": "标准模式" },
        { "value": "enhanced", "label": "增强模式" },
        { "value": "deep", "label": "深度模式" },
        { "value": "expert", "label": "专家模式" }
      ],
      "help": "专家模式为成功率优先的可审计配置，需管理员确认风险说明后使用。"
    },
    { "name": "includeHealthCommission", "label": "是否医院/医疗机构", "type": "boolean", "default": false },
    { "name": "personArgs", "label": "个人被执行查询", "type": "text", "required": false, "help": "多个时可用换行或逗号分隔，每项格式为 姓名|身份证号。" }
  ],
  "startupNotice": [
    "WorkBuddy 只有电脑版 Windows 入口可正常运行，使用 PowerShell 入口。",
    "WorkBuddy 手机端不作为可用运行入口；Linux 手机办公任务请使用豆包 App。",
    "正式司法/执行报告要求法院官方页面成功查询截图；补充材料不能替代正式证据。",
    "不得模拟、不得生成样例、不得编造数据。"
  ],
  "outputPattern": "贷后查询-{companyName}-{yyyyMMdd}.docx",
  "rules": {
    "challengeHandling": "managed",
    "dynamicScreenshotCount": true,
    "rejectInvalidScreenshots": true,
    "sourceAuditRequired": true,
    "subjectGraphRequired": true
  }
}
