{
  "id": "ccb-post-loan-doubao",
  "displayName": "CCB贷前贷后查询",
  "mode": "browser-task",
  "targetEnvironments": [
    "doubao-app-office-task-skill",
    "ubuntu-22.04-cloud-computer",
    "linux-browser-task"
  ],
  "doubaoAppEntrypoint": "run_doubao_app.sh",
  "doubaoAppPreflight": "preflight_doubao_app.sh",
  "runtimeLimits": {
    "os": "Ubuntu 22.04.3 LTS x86_64",
    "foregroundSeconds": 120,
    "backgroundSeconds": 600,
    "processMemoryGB": 2,
    "diskGB": 50,
    "singleFileMB": 500,
    "noRoot": true,
    "noListeningService": true,
    "noDocker": true,
    "noGpu": true
  },
  "inputContract": {
    "single": {
      "companyName": { "type": "string", "required": true },
      "orgCode": { "type": "string", "required": false },
      "mode": { "type": "enum", "values": ["standard", "enhanced", "deep", "expert"], "default": "enhanced" },
      "personChecks": { "type": "array", "required": false, "itemFormat": "姓名|身份证号", "batchSupported": false },
      "includeHealthCommission": { "type": "boolean", "default": "auto" }
    },
    "batch": {
      "companies": { "type": "array", "required": true },
      "orgCodes": { "type": "array", "required": false },
      "mode": { "type": "enum", "values": ["standard", "enhanced", "deep", "expert"], "default": "enhanced" }
    }
  },
  "queryModes": [
    { "value": "standard", "label": "标准模式", "description": "安全稳定，适合普通查询。" },
    { "value": "enhanced", "label": "增强模式", "description": "默认推荐，平衡成功率、性能与合规护栏。" },
    { "value": "deep", "label": "深度模式", "description": "更强查询覆盖、会话复用、重试和关联主体补查。" },
    { "value": "expert", "label": "专家模式", "description": "成功率优先的最积极可审计配置，需确认风险说明。" }
  ],
  "hardRules": [
    "不得模拟！",
    "不得墨迹！",
    "不能胡编乱造数据！",
    "必须原原本本执行项目脚本！",
    "不得生成演示报告、样例报告、合成截图或占位数据。",
    "未确认真实结果页或真实无结果页前不得截图。",
    "失败就返回失败原因、补证清单或可重试状态，不得伪装成功。"
  ],
  "startupNotice": [
    "用户只需要输入企业名；批量时可粘贴多个企业名。",
    "豆包 App 办公任务模式必须优先直接执行 run_doubao_app.sh。",
    "正式司法/执行报告必须来自法院官方页面成功查询截图；补充材料不能替代正式证据。",
    "遇到强校验源时，按策略进入托管确认或补证队列，不得编造数据。"
  ],
  "stateMachine": [
    "collect_subject",
    "run_preflight",
    "execute_project_runner",
    "fill_subject_fields",
    "validate_result_state",
    "capture_confirmed_pages",
    "build_report",
    "collect_batch_reports"
  ],
  "validationRules": {
    "enforcementMustReachResultState": true,
    "rejectLoginCaptchaErrorBlankPages": true,
    "dynamicScreenshots": true,
    "completeSearchEvidenceOnly": true,
    "batchReportsFolder": "reports",
    "batchEvidenceFolder": "evidence",
    "challengeHandling": "managed"
  },
  "outputContract": {
    "singleReportName": "贷后查询-{companyName}-{yyyyMMdd}.docx",
    "batchFolderName": "batch-post-loan-{yyyyMMdd-HHmmss}-{pid}",
    "reportsFolder": "reports",
    "evidenceFolder": "evidence",
    "summaryFile": "batch-summary.json"
  },
  "optionalImageTextRecognition": {
    "provider": "optional-local-component",
    "defaultEnabled": false,
    "policy": "Only for authorized low-risk image text recognition tasks. Judicial, government, and execution sources keep this disabled by default unless an approved policy changes source admission."
  }
}
