{
  "id": "ccb-pre-post-loan-query-doubao",
  "displayName": "CCB贷前贷后查询",
  "mode": "browser-task",
  "targetEnvironments": ["pc-local-browser", "web-remote-browser", "mobile-supervised-task"],
  "localEntrypoint": "run_doubao_local.ps1",
  "startupNotice": [
    "用户只需要输入企业名；批量时可粘贴多个企业名。",
    "无需司法门户时尽量后台执行，不打扰用户。",
    "如果任务包含裁判文书网或执行信息公开网，请只在需要登录或验证码时请求用户接管。",
    "验证码错误或页面没有进入查询结果/无结果时，不截图，继续等待有效结果。"
  ],
  "stateMachine": [
    "collect_subject",
    "open_manual_pages",
    "wait_login_or_user_takeover",
    "fill_non_captcha_fields",
    "wait_captcha_input",
    "submit_query",
    "validate_result_state",
    "retry_on_captcha_or_load_failure",
    "capture_confirmed_pages",
    "build_report",
    "collect_batch_reports"
  ],
  "validationRules": {
    "enforcementMustReachResultState": true,
    "rejectLoginCaptchaErrorBlankPages": true,
    "dynamicScreenshots": true,
    "completeSearchEvidenceOnly": true,
    "batchReportsFolder": "reports",
    "batchEvidenceFolder": "evidence",
    "captchaBypass": false
  },
  "outputContract": {
    "singleReportName": "贷后查询-{companyName}-{yyyyMMdd}.docx",
    "batchFolderName": "batch-post-loan-{yyyyMMdd-HHmmss}-{pid}",
    "reportsFolder": "reports",
    "evidenceFolder": "evidence",
    "summaryFile": "batch-summary.json"
  },
  "optionalOcr": {
    "provider": "ddddocr",
    "defaultEnabled": false,
    "policy": "Only for compliant OCR tasks. Do not use to bypass judicial/enforcement captcha or access controls."
  }
}
