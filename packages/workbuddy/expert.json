{
  "id": "ccb-pre-post-loan-query",
  "displayName": "CCB贷前贷后查询",
  "description": "为非技术用户提供表单化的贷前/贷后外部信息查询、截图和 Word 报告生成。",
  "entrypoint": "../core-skill/workbuddy/run_workbuddy.ps1",
  "preflight": "../core-skill/scripts/preflight_workbuddy.ps1",
  "fields": [
    { "name": "companyName", "label": "企业名称", "type": "text", "required": true },
    { "name": "orgCode", "label": "统一社会信用代码/组织机构代码", "type": "text", "required": false },
    { "name": "includeHealthCommission", "label": "医院/医疗机构", "type": "boolean", "default": false },
    { "name": "includePersons", "label": "同步查法人/实控人被执行信息", "type": "boolean", "default": false },
    { "name": "persons", "label": "个人名单", "type": "array", "visibleWhen": "includePersons=true" }
  ],
  "startupNotice": [
    "请登录中国裁判文书网。",
    "执行公开网可能需要登录，页面也可能加载失败，系统会自动重试。",
    "请在每个执行公开网页面只输入验证码。",
    "验证码错误时系统不会截图，会等待你重新输入。"
  ]
}
